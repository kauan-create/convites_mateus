generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Familia {
  id           String      @id @default(cuid())
  nome_familia String
  convidados   Convidado[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("familias")
}

model Convidado {
  id                 String   @id @default(cuid())
  nome               String
  telefone           String?
  acompanhantes      Int      @default(0)
  status_confirmacao String   @default("Pendente")
  observacoes        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  familiaId String?
  familia   Familia? @relation(fields: [familiaId], references: [id], onDelete: SetNull)

  convite Convite?

  @@map("convidados")
}

model Convite {
  id        String   @id @default(cuid())
  codigo    String   @unique
  type      String   @default("individual")
  title     String
  link      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    String   @default("Pendente")

  convidadoId String    @unique
  convidado   Convidado @relation(fields: [convidadoId], references: [id], onDelete: Cascade)

  @@map("convites")
}
